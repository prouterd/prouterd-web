<header class="top-bar" role="banner">
  <div class="top-bar__left">
    <span class="top-bar__brand">Process Router</span>
    <span class="top-bar__router"><%= status[:router] %></span>
  </div>
  <div class="top-bar__right">
    <span class="top-bar__stat">active: #<%= status[:active_commit] || "—" %></span>
    <span class="top-bar__stat">boot: #<%= status[:boot_commit] || "—" %></span>
    <span class="top-bar__stat top-bar__stat--<%= status[:config_drift] ? "warn" : "ok" %>">
      drift: <%= status[:config_drift] ? "yes" : "no" %>
    </span>
    <span class="top-bar__stat">workers: <%= status[:workers] %></span>
    <span class="top-bar__stat">queue: <%= status[:queue_depth] %></span>
    <span class="top-bar__health top-bar__health--<%= status[:healthy] ? "ok" : "fail" %>">
      <%= status[:healthy] ? "● healthy" : "● degraded" %>
    </span>
  </div>
</header>
