<header class="inspector-header">
  <div class="inspector-header__title">Step <%= @step[:id] %>: <%= @step[:block_name] %> · run <%= @run_uid %></div>
  <div class="inspector-header__meta">
    <span><b>status</b> <span class="status-<%= @step[:status] %>"><%= @step[:status] %></span></span>
    <span><b>attempt</b> <%= @step[:attempt] %></span>
    <span><b>image</b> <%= @step[:image] || "—" %></span>
    <span><b>exit</b> <%= @step[:exit_code].nil? ? "—" : @step[:exit_code] %></span>
    <span><b>duration</b> <%= @step[:duration_ms] ? "#{@step[:duration_ms]} ms" : "—" %></span>
    <% if @step[:error_type] %>
      <span><b>error</b> <span class="status-failed"><%= @step[:error_type] %></span></span>
    <% end %>
    <span><a href="#" data-open-window="run" data-open-resource="<%= @run_uid %>">open run inspector</a></span>
  </div>
  <div class="inspector-header__actions">
    <button type="button" class="action__btn"
            data-run-action="replay-from"
            data-run-uid="<%= @run_uid %>"
            data-from-block="<%= @step[:block_name] %>"
            data-confirm="Replay run <%= @run_uid %> starting at block '<%= @step[:block_name] %>'?">
      replay from this step
    </button>
  </div>
</header>

<nav class="tabs" role="tablist">
  <button type="button" class="tab tab--active" data-tab="input">Input</button>
  <button type="button" class="tab"             data-tab="output">Output</button>
  <button type="button" class="tab"             data-tab="logs">Logs</button>
  <button type="button" class="tab"             data-tab="artifacts">Artifacts</button>
</nav>

<div class="tab-panel" data-tab-panel="input">
  <% if @step[:input_json].nil? %>
    <div class="logs__empty">no input recorded</div>
  <% else %>
    <%== render_json(@step[:input_json]) %>
  <% end %>
</div>

<div class="tab-panel" data-tab-panel="output" hidden>
  <% if @step[:output_json].nil? %>
    <div class="logs__empty">no output recorded</div>
  <% else %>
    <%== render_json(@step[:output_json]) %>
  <% end %>
  <% if @step[:error_message] %>
    <div class="step__error">
      <div class="step__error-label">Error message</div>
      <pre class="step__error-body"><%= @step[:error_message] %></pre>
    </div>
  <% end %>
</div>

<div class="tab-panel" data-tab-panel="logs" hidden>
  <div class="logs">
    <% if @step_logs.empty? %>
      <div class="logs__empty">no log entries for this step</div>
    <% else %>
      <% @step_logs.each do |l| %>
        <div class="logs__line logs__line--<%= l[:stream] %>">
          <span class="logs__ts"><%= format_log_ts(l[:created_at]) %></span>
          <span class="logs__stream"><%= l[:stream] %></span>
          <span class="logs__content"><%= l[:content] %></span>
        </div>
      <% end %>
    <% end %>
  </div>
</div>

<div class="tab-panel" data-tab-panel="artifacts" hidden>
  <table class="data-table">
    <thead>
      <tr><th>Name</th><th>Size</th><th>Type</th><th>Created</th></tr>
    </thead>
    <tbody>
      <% @step_artifacts.each do |a| %>
        <tr>
          <td><%= a[:name] %></td>
          <td><%= format_bytes(a[:size_bytes]) %></td>
          <td><%= a[:content_type] || "—" %></td>
          <td><%= a[:created_at] %></td>
        </tr>
      <% end %>
      <% if @step_artifacts.empty? %>
        <tr><td colspan="4" class="data-table__empty">No artifacts for this step.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
