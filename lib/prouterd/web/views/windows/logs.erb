<header class="inspector-header">
  <div class="inspector-header__title">Logs: <%= @run_uid %><%= " · step #{@step_id}" if @step_id %></div>
  <div class="inspector-header__meta">
    <span><b>entries</b> <%= @logs.size %></span>
    <span><b>streams</b> <%= @logs.map { |l| l[:stream] }.uniq.sort.join(", ") %></span>
    <% if @run_uid %>
      <span><a href="#" data-open-window="run" data-open-resource="<%= @run_uid %>">open run inspector</a></span>
    <% end %>
  </div>
</header>

<div class="logs">
  <% if @logs.empty? %>
    <div class="logs__empty">no log entries</div>
  <% else %>
    <% @logs.each do |l| %>
      <div class="logs__line logs__line--<%= l[:stream] %>">
        <span class="logs__ts"><%= format_log_ts(l[:created_at]) %></span>
        <span class="logs__stream"><%= l[:stream] %></span>
        <% if !@step_id %>
          <span class="logs__step">step <%= l[:step_id] || "—" %></span>
        <% end %>
        <span class="logs__content"><%= l[:content] %></span>
      </div>
    <% end %>
  <% end %>
</div>
