<table class="data-table">
  <thead>
    <tr>
      <th>Run</th>
      <th>Process</th>
      <th>Status</th>
      <th>Duration</th>
      <th>Started</th>
      <th>Trigger</th>
    </tr>
  </thead>
  <tbody>
    <% @runs.each do |r| %>
      <tr class="data-table__row--clickable" data-open-window="run" data-open-resource="<%= r[:run_uid] %>">
        <td><%= r[:run_uid] %></td>
        <td><%= r[:process_name] %></td>
        <td class="status-<%= r[:status] %>"><%= r[:status] %></td>
        <td><%= r[:duration_ms] ? "#{r[:duration_ms]} ms" : "—" %></td>
        <td><%= r[:started_at] || "—" %></td>
        <td><%= r[:trigger] || "—" %></td>
      </tr>
    <% end %>
    <% if @runs.empty? %>
      <tr><td colspan="6" class="data-table__empty">No runs yet.</td></tr>
    <% end %>
  </tbody>
</table>

<%
  base_query = +"limit=#{@limit}"
  base_query << "&process=#{Rack::Utils.escape(@process_filter)}" if @process_filter
  prev_offset = [@offset - @limit, 0].max
  next_offset = @offset + @limit
  last_offset = ((@total - 1) / @limit) * @limit
  last_offset = 0 if last_offset.negative?
  shown_from  = @runs.empty? ? 0 : @offset + 1
  shown_to    = @offset + @runs.size
%>
<footer class="pagination">
  <span class="pagination__info">
    <% if @total.zero? %>
      0 runs
    <% else %>
      runs <%= shown_from %>–<%= shown_to %> of <%= @total %><%= " · process: #{@process_filter}" if @process_filter %>
    <% end %>
  </span>
  <span class="pagination__buttons">
    <button type="button" class="pagination__btn"
            <%= "disabled" if @offset == 0 %>
            data-page-link="/windows/runs?<%= base_query %>&offset=0">first</button>
    <button type="button" class="pagination__btn"
            <%= "disabled" if @offset == 0 %>
            data-page-link="/windows/runs?<%= base_query %>&offset=<%= prev_offset %>">prev</button>
    <button type="button" class="pagination__btn"
            <%= "disabled" if next_offset >= @total %>
            data-page-link="/windows/runs?<%= base_query %>&offset=<%= next_offset %>">next</button>
    <button type="button" class="pagination__btn"
            <%= "disabled" if @offset >= last_offset %>
            data-page-link="/windows/runs?<%= base_query %>&offset=<%= last_offset %>">last</button>
  </span>
</footer>
