<table class="data-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Status</th>
      <th>Blocks</th>
      <th>Routes</th>
      <th>Queue</th>
      <th>Last status</th>
    </tr>
  </thead>
  <tbody>
    <% @processes.each do |p| %>
      <tr class="data-table__row--clickable" data-open-window="process" data-open-resource="<%= p[:name] %>">
        <td><%= p[:name] %></td>
        <td class="status-<%= p[:status] %>"><%= p[:status] %></td>
        <td><%= p[:blocks] %></td>
        <td><%= p[:routes] %></td>
        <td><%= p[:queue] %></td>
        <td class="status-<%= p[:last_status] %>"><%= p[:last_status] || "—" %></td>
      </tr>
    <% end %>
    <% if @processes.empty? %>
      <tr><td colspan="6" class="data-table__empty">No processes configured.</td></tr>
    <% end %>
  </tbody>
</table>
