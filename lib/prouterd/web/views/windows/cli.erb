<div class="cli" data-cli-session="<%= @session_id %>">
  <div class="cli__output" role="log" aria-live="polite"></div>
  <div class="cli__inputline">
    <span class="cli__prompt"><%= @initial_prompt %></span>
    <input
      class="cli__input"
      type="text"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="CLI input"
    >
  </div>
</div>
