<header class="inspector-header">
  <div class="inspector-header__title">Run: <%= @run[:run_uid] %></div>
  <div class="inspector-header__meta">
    <span><b>process</b> <a href="#" data-open-window="process" data-open-resource="<%= @run[:process_name] %>"><%= @run[:process_name] %></a></span>
    <span><b>status</b> <span class="status-<%= @run[:status] %>"><%= @run[:status] %></span></span>
    <span><b>started</b> <%= @run[:started_at] || "—" %></span>
    <span><b>duration</b> <%= @run[:duration_ms] ? "#{@run[:duration_ms]} ms" : "—" %></span>
    <span><b>config</b> #<%= @run[:config_commit] || "—" %></span>
    <span><b>trigger</b> <%= @run[:trigger] || "—" %></span>
    <% if @run[:replay_of] %>
      <span><b>replay of</b> <a href="#" data-open-window="run" data-open-resource="<%= @run[:replay_of] %>"><%= @run[:replay_of] %></a></span>
    <% end %>
  </div>
  <div class="inspector-header__meta">
    <span><a href="#" data-open-window="logs"      data-open-resource="<%= @run[:run_uid] %>">logs</a></span>
    <span><a href="#" data-open-window="context"   data-open-resource="<%= @run[:run_uid] %>">context</a></span>
    <span><a href="#" data-open-window="artifacts" data-open-resource="<%= @run[:run_uid] %>">artifacts</a></span>
  </div>
  <div class="inspector-header__actions">
    <% if %w[queued running].include?(@run[:status]) %>
      <button type="button" class="action__btn action__btn--danger"
              data-run-action="cancel"
              data-run-uid="<%= @run[:run_uid] %>"
              data-confirm="Cancel run <%= @run[:run_uid] %>?">
        cancel run
      </button>
    <% end %>
    <% if @run[:replayable] %>
      <button type="button" class="action__btn"
              data-run-action="replay"
              data-run-uid="<%= @run[:run_uid] %>"
              data-confirm="Replay run <%= @run[:run_uid] %> from the start?">
        replay run
      </button>
    <% end %>
  </div>
</header>

<nav class="tabs" role="tablist">
  <button type="button" class="tab tab--active" data-tab="summary">Summary</button>
  <button type="button" class="tab"             data-tab="steps">Steps</button>
</nav>

<div class="tab-panel" data-tab-panel="summary">
  <table class="kv-table">
    <tbody>
      <tr><td>Run</td>           <td><%= @run[:run_uid] %></td></tr>
      <tr><td>Process</td>       <td><%= @run[:process_name] %></td></tr>
      <tr><td>Status</td>        <td class="status-<%= @run[:status] %>"><%= @run[:status] %></td></tr>
      <tr><td>Started</td>       <td><%= @run[:started_at] || "—" %></td></tr>
      <tr><td>Finished</td>      <td><%= @run[:finished_at] || "—" %></td></tr>
      <tr><td>Duration</td>      <td><%= @run[:duration_ms] ? "#{@run[:duration_ms]} ms" : "—" %></td></tr>
      <tr><td>Config commit</td> <td>#<%= @run[:config_commit] || "—" %></td></tr>
      <tr><td>Trigger</td>       <td><%= @run[:trigger] || "—" %></td></tr>
      <tr><td>Interface</td>     <td><%= @run[:interface_name] || "—" %></td></tr>
      <tr><td>Replayable</td>    <td><%= @run[:replayable] ? "yes" : "no" %></td></tr>
      <% if @run[:error_summary] %>
        <tr><td>Error</td><td class="status-failed"><%= @run[:error_summary] %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="tab-panel" data-tab-panel="steps" hidden>
  <table class="data-table">
    <thead>
      <tr>
        <th>Block</th>
        <th>Status</th>
        <th>Attempt</th>
        <th>Image</th>
        <th>Exit</th>
        <th>Error</th>
        <th>Duration</th>
        <th>Started</th>
      </tr>
    </thead>
    <tbody>
      <% @steps.each do |s| %>
        <tr class="data-table__row--clickable" data-open-window="step" data-open-resource="<%= @run[:run_uid] %>/<%= s[:id] %>">
          <td><%= s[:block_name] %></td>
          <td class="status-<%= s[:status] %>"><%= s[:status] %></td>
          <td><%= s[:attempt] %></td>
          <td><%= s[:image] || "—" %></td>
          <td><%= s[:exit_code].nil? ? "—" : s[:exit_code] %></td>
          <td><%= s[:error_type] || "—" %></td>
          <td><%= s[:duration_ms] ? "#{s[:duration_ms]} ms" : "—" %></td>
          <td><%= s[:started_at] || "—" %></td>
        </tr>
      <% end %>
      <% if @steps.empty? %>
        <tr><td colspan="8" class="data-table__empty">No steps yet.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
