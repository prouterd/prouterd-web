<table class="data-table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Source type</th>
      <th>Source ref</th>
      <th>Used by</th>
      <th>Status</th>
    </tr>
  </thead>
  <tbody>
    <% @secrets.each do |s| %>
      <tr>
        <td><%= s[:name] %></td>
        <td><%= s[:source_type] || "—" %></td>
        <td><%= s[:source_ref] || "—" %></td>
        <td><%= Array(s[:used_by]).any? ? Array(s[:used_by]).join(", ") : "—" %></td>
        <td class="status-<%= s[:status] %>"><%= s[:status] %></td>
      </tr>
    <% end %>
    <% if @secrets.empty? %>
      <tr><td colspan="5" class="data-table__empty">No secrets declared.</td></tr>
    <% end %>
  </tbody>
</table>
<p class="window-placeholder__hint" style="padding: 8px 12px; margin: 0;">
  Secret values are never displayed — only their declared source reference.
</p>
