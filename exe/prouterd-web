#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "prouterd/web"
require "rackup"

options = {
  host:        "127.0.0.1",
  port:        9292,
  core_url:    ENV["PROUTERD_CORE_URL"],
  core_token:  ENV["PROUTERD_CORE_TOKEN"],
  admin_token: ENV["PROUTERD_WEB_ADMIN_TOKEN"]
}

OptionParser.new do |o|
  o.banner = <<~BAN
    Usage: prouterd-web --core-url URL [options]

    The console reaches an prouterd daemon over HTTP /v1 + WS /v1/events
    + WS /v1/cli. Spin one up via `prouter serve --runner stub` for
    dev / smoke, or against a real production daemon.

    Required:
      --core-url URL          prouterd daemon (env: PROUTERD_CORE_URL)

    Auth:
      --core-token TOKEN      bearer for /v1 (env: PROUTERD_CORE_TOKEN)
      --admin-token TOKEN     web-console session token (env: PROUTERD_WEB_ADMIN_TOKEN)
      --admin-token-env VAR   read admin token from another env var

    Networking:
      -p / --port PORT        bind port [9292]
      -H / --host HOST        bind host [127.0.0.1]

  BAN

  o.on("-pPORT", "--port=PORT", Integer)               { |v| options[:port] = v }
  o.on("-HHOST", "--host=HOST", String)                { |v| options[:host] = v }
  o.on("--core-url=URL", String)                       { |v| options[:core_url]   = v }
  o.on("--core-token=TOKEN", String)                   { |v| options[:core_token] = v }
  o.on("--admin-token=TOKEN", String)                  { |v| options[:admin_token] = v }
  o.on("--admin-token-env=VAR", String)                { |v| options[:admin_token] = ENV[v] }
  o.on_tail("-v", "--version") { puts Prouterd::Web::VERSION; exit }
  o.on_tail("-h", "--help")    { puts o; exit }
end.parse!

if options[:core_url].nil? || options[:core_url].empty?
  warn "prouterd-web: --core-url is required (or set PROUTERD_CORE_URL)"
  exit 2
end

# ----- adapter -----
client  = Prouterd::Web::CoreClient.new(
  base_url: options[:core_url],
  token:    options[:core_token]
)
adapter = Prouterd::Web::Adapters::HttpApiAdapter.new(client: client)

# ----- live updates: WS /v1/events → Broadcaster -----
broadcaster     = Prouterd::Web::Broadcaster.new
events_consumer = Prouterd::Web::EventsConsumer.new(broadcaster: broadcaster)

Prouterd::Web::EventMachineRunner.ensure_running!
events_url = options[:core_url].sub(/\Ahttp/, "ws") + "/v1/events"
ws_headers = options[:core_token] ? { "Authorization" => "Bearer #{options[:core_token]}" } : {}
EM.next_tick do
  require "faye/websocket"
  ws = Faye::WebSocket::Client.new(events_url, [], headers: ws_headers)
  events_consumer.attach(->(frame) { ws.send(frame) })
  ws.on(:open)    { events_consumer.on_open }
  ws.on(:message) { |e| events_consumer.on_message(e.data) }
  ws.on(:close)   { events_consumer.on_close }
end

# ----- CLI: WS /v1/cli/:session_id -----
cli_bridge = Prouterd::Web::CliBridge.new(
  core_url: options[:core_url],
  token:    options[:core_token]
)

# ----- App -----
app = Prouterd::Web::App.with_adapter(
  adapter,
  auth_token:      options[:admin_token],
  events_consumer: events_consumer,
  cli_bridge:      cli_bridge
)

handler = Rackup::Handler.get("puma")

warn "prouterd-web #{Prouterd::Web::VERSION} on http://#{options[:host]}:#{options[:port]}"
warn "  core:   #{options[:core_url]}"
warn "  events: WS /v1/events"
warn "  cli:    WS /v1/cli/:session_id"
warn "  bearer: #{options[:core_token] ? 'configured' : 'NONE — open daemon'}"
warn "  auth:   #{options[:admin_token] ? 'enabled' : 'DISABLED — set --admin-token for production'}"

# Cluster-mode safety: each Puma worker would open its own
# EventsConsumer + EM reactor + per-session CliBridge connection. Browser
# events would dedup-fail. We're single-worker until that's solved (see
# README's "Caveats" section).
handler.run(app, Host: options[:host], Port: options[:port], workers: 0)
